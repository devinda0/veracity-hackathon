# Project
COMPOSE_PROJECT_NAME=vector-agents

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin123
MONGO_DATABASE=vector-agents
MONGO_URI=mongodb://admin:admin123@mongo:27017/vector-agents?authSource=admin&replicaSet=rs0

# Qdrant
QDRANT_URL=http://qdrant:6333

# Redis
REDIS_URL=redis://redis:6379/0

# PostgreSQL
POSTGRES_DB=vector_agents
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/vector_agents

# App secrets
JWT_SECRET=dev-secret-change-in-prod
OPENAI_API_KEY=sk-...

# External data providers
FIRECRAWL_API_KEY=
SERPAPI_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
HN_ALGOLIA_APP_ID=
META_AD_LIBRARY_ACCESS_TOKEN=
LINKEDIN_API_KEY=
USPTO_API_KEY=

